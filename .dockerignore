# Local environment and secrets: keep examples/templates, exclude real values.
.env
.env.*
!.env.example
!.env.*.example
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example
secrets/*
secrets/**/*
**/secrets/*
**/secrets/**/*
!secrets/*.example
!secrets/**/*.example
!**/secrets/*.example
!**/secrets/**/*.example
*.key
**/*.key
*.pem
**/*.pem
!*.key.example
!**/*.key.example
!*.pem.example
!**/*.pem.example

# Runtime SQLite state must never enter image build contexts.
data/
**/data/
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm
*-wal
*-shm
**/*.db
**/*.sqlite
**/*.sqlite3
**/*.db-wal
**/*.db-shm
**/*.sqlite-wal
**/*.sqlite-shm
**/*.sqlite3-wal
**/*.sqlite3-shm
**/*-wal
**/*-shm
